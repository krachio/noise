#!/usr/bin/env bash
# Quick integration smoke test — starts krach-engine, plays a beat, exits.
# Usage: ./bin/test-beat
set -e
REPO="$(cd "$(dirname "$0")/.." && pwd)"

cargo build --bin krach-engine -q --manifest-path "$REPO/Cargo.toml"

TMPDIR_NATIVE="$(python3 -c 'import tempfile; print(tempfile.gettempdir())')"
ENGINE_SOCK="${TMPDIR_NATIVE}/krach-engine-test-beat.sock"
rm -f "$ENGINE_SOCK"

NOISE_SOCKET="$ENGINE_SOCK" \
NOISE_DSP_DIR="$HOME/.krach/dsp" \
RUST_LOG=warn "$REPO/target/debug/krach-engine" &
ENGINE_PID=$!
trap "kill $ENGINE_PID 2>/dev/null" EXIT

# Wait for socket
for i in $(seq 1 50); do [ -S "$ENGINE_SOCK" ] && break; sleep 0.1; done
[ -S "$ENGINE_SOCK" ] || { echo "engine socket not ready"; exit 1; }

PYTHON="$REPO/midiman-frontend/.venv/bin/python"
[ -f "$PYTHON" ] || PYTHON=python3

exec "$PYTHON" -c "
import sys, time, threading, tempfile, os
sys.path.insert(0, '${REPO}/midiman-frontend/src')
from midiman_frontend import Graph, Session

mm = Session(socket_path='${ENGINE_SOCK}')
mm.connect()

# ── Step 1: connectivity ──────────────────────────────────────────────────
nodes = mm.list_nodes()
print(f'step 1 — nodes: {nodes}')
assert 'dac' in nodes, 'engine not responding'
assert 'faust:kit' in nodes, 'faust:kit not loaded — did you run a session first?'

# ── Step 2: load drum kit graph ───────────────────────────────────────────
mm.load_graph(
    Graph()
    .node('kit', 'faust:kit', kick=0, hat=0, snare=0, freq=55.0, bass=0)
    .node('out', 'dac')
    .connect('kit', 'out', 'out', 'in')
    .expose('kick',  'kit', 'kick')
    .expose('hat',   'kit', 'hat')
    .expose('snare', 'kit', 'snare')
    .expose('freq',  'kit', 'freq')
    .expose('bass',  'kit', 'bass')
    .build()
)
print('step 2 — graph loaded')
time.sleep(0.2)

# ── Step 3: play beat via direct set_ctrl (no OSC) ───────────────────────
def trig(ctrl):
    mm.set_ctrl(ctrl, 0.0); time.sleep(0.012); mm.set_ctrl(ctrl, 1.0)

BPM   = 120
TICK  = 60 / BPM / 4   # 16th note
BARS  = 8
stop  = threading.Event()

bass_line = [43.7, 55.0, 65.4, 43.7, 55.0, 87.3, 65.4, 55.0]

def drum_loop():
    kick_steps  = {0, 8}
    snare_steps = {4, 12}
    hat_steps   = {0, 2, 4, 6, 8, 10, 12, 14}
    t0 = time.perf_counter()
    for i in range(BARS * 16):
        s = i % 16
        if s in kick_steps:  trig('kick')
        if s in snare_steps: trig('snare')
        if s in hat_steps:   trig('hat')
        time.sleep(max(0, t0 + (i + 1) * TICK - time.perf_counter()))
    stop.set()

def bass_loop():
    t0 = time.perf_counter()
    i  = 0
    while not stop.is_set():
        mm.set_ctrl('freq', bass_line[i % len(bass_line)])
        trig('bass')
        time.sleep(max(0, t0 + (i + 1) * TICK * 3 - time.perf_counter()))
        i += 1

print(f'step 3 — playing {BARS} bars at {BPM} BPM (you should hear drums + bass)')
t1 = threading.Thread(target=drum_loop, daemon=True)
t2 = threading.Thread(target=bass_loop, daemon=True)
t1.start(); t2.start(); t1.join()

mm.shutdown()
mm.disconnect()
print('done')
"
