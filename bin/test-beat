#!/usr/bin/env bash
# Quick integration smoke test — starts soundman, plays a beat, exits.
# Usage: ./bin/test-beat
set -e
REPO="$(cd "$(dirname "$0")/.." && pwd)"

cargo build --bin soundman -q --manifest-path "$REPO/Cargo.toml"

SOUNDMAN_DSP_DIR="$HOME/.krach/dsp" \
SOUNDMAN_OSC_ADDR="127.0.0.1:9001" \
RUST_LOG=warn "$REPO/target/debug/soundman" &
SOUNDMAN_PID=$!
trap "kill $SOUNDMAN_PID 2>/dev/null" EXIT
sleep 1.5

PYTHON="$REPO/soundman-frontend/.venv/bin/python"
[ -f "$PYTHON" ] || PYTHON=python3

exec "$PYTHON" -c "
import sys, time, threading
sys.path.insert(0, '${REPO}/soundman-frontend/src')
from soundman_frontend import Graph, SoundmanSession

sm = SoundmanSession(host='127.0.0.1', port=9001)

# ── Step 1: connectivity ──────────────────────────────────────────────────
nodes = sm.list_nodes()
print(f'step 1 — nodes: {nodes}')
assert 'dac' in nodes, 'soundman not responding'
assert 'faust:kit' in nodes, 'faust:kit not loaded — did you run the smoke test before?'

# ── Step 2: load drum kit graph ───────────────────────────────────────────
sm.load_graph(
    Graph()
    .node('kit', 'faust:kit', kick=0, hat=0, snare=0, freq=55.0, bass=0)
    .node('out', 'dac')
    .connect('kit', 'out', 'out', 'in')
    .expose('kick',  'kit', 'kick')
    .expose('hat',   'kit', 'hat')
    .expose('snare', 'kit', 'snare')
    .expose('freq',  'kit', 'freq')
    .expose('bass',  'kit', 'bass')
    .build()
)
print('step 2 — graph loaded')
time.sleep(0.2)

# ── Step 3: play beat via direct sm.set() (no midiman) ───────────────────
def trig(ctrl):
    sm.set(ctrl, 0.0); time.sleep(0.012); sm.set(ctrl, 1.0)

BPM   = 120
TICK  = 60 / BPM / 4   # 16th note
BARS  = 8
stop  = threading.Event()

bass_line = [43.7, 55.0, 65.4, 43.7, 55.0, 87.3, 65.4, 55.0]

def drum_loop():
    kick_steps  = {0, 8}
    snare_steps = {4, 12}
    hat_steps   = {0, 2, 4, 6, 8, 10, 12, 14}
    t0 = time.perf_counter()
    for i in range(BARS * 16):
        s = i % 16
        if s in kick_steps:  trig('kick')
        if s in snare_steps: trig('snare')
        if s in hat_steps:   trig('hat')
        time.sleep(max(0, t0 + (i + 1) * TICK - time.perf_counter()))
    stop.set()

def bass_loop():
    t0 = time.perf_counter()
    i  = 0
    while not stop.is_set():
        sm.set('freq', bass_line[i % len(bass_line)])
        trig('bass')
        time.sleep(max(0, t0 + (i + 1) * TICK * 3 - time.perf_counter()))
        i += 1

print(f'step 3 — playing {BARS} bars at {BPM} BPM (you should hear drums + bass)')
t1 = threading.Thread(target=drum_loop, daemon=True)
t2 = threading.Thread(target=bass_loop, daemon=True)
t1.start(); t2.start(); t1.join()

sm.shutdown()
print('done')
"
