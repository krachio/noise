#!/usr/bin/env bash
# Spy: intercept midiman→soundman OSC and show scheduler cycle debug
set -e
REPO="$(cd "$(dirname "$0")/.." && pwd)"
TMPDIR_NATIVE="$(python3 -c 'import tempfile; print(tempfile.gettempdir())')"
MIDIMAN_SOCK="${TMPDIR_NATIVE}/midiman.sock"
rm -f "$MIDIMAN_SOCK"

MIDIMAN_SOCKET="$MIDIMAN_SOCK" \
MIDIMAN_OSC_TARGET="127.0.0.1:9002" \
  "$REPO/target/debug/midiman" 2>/tmp/midiman-sched.log &
MIDIMAN_PID=$!
cleanup() { kill $MIDIMAN_PID 2>/dev/null; wait 2>/dev/null; }
trap cleanup EXIT INT TERM
sleep 1

PYTHON="$REPO/soundman-frontend/.venv/bin/python"
[ -f "$PYTHON" ] || PYTHON=python3

exec "$PYTHON" - <<'PYEOF'
import sys, socket, threading, time
sys.path.insert(0, "/Users/jonkhler/dev/noise/midiman-frontend/src")
sys.path.insert(0, "/Users/jonkhler/dev/noise/soundman-frontend/src")

from midiman_frontend import Session
from midiman_frontend.ir import OscFloat, OscStr
from midiman_frontend.pattern import osc as midi_osc
import tempfile, os

spy = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
spy.bind(("127.0.0.1", 9002))
spy.settimeout(0.01)
log = []
t0 = time.perf_counter()
done = threading.Event()

def listen():
    from pythonosc import osc_packet, osc_message
    while not done.is_set():
        try:
            data, _ = spy.recvfrom(4096)
            pkt = osc_packet.OscPacket(data)
            msg = pkt.messages[0].message
            if isinstance(msg, osc_message.OscMessage):
                log.append((time.perf_counter() - t0, list(msg.params)))
        except: pass

threading.Thread(target=listen, daemon=True).start()

sock = os.path.join(tempfile.gettempdir(), "midiman.sock")
mm = Session(socket_path=sock)
mm.connect()

def sc(label, value):
    return midi_osc("/soundman/set", OscStr(label), OscFloat(value))

mm.tempo = 120
mm.launch({
    "kick":  sc("kick",  1.0) + sc("kick",  0.0) + sc("kick",  1.0) + sc("kick",  0.0),
    "snare": sc("snare", 0.0) + sc("snare", 1.0) + sc("snare", 0.0) + sc("snare", 1.0),
    "hat":   sc("hat",   1.0) + sc("hat",   0.0) + sc("hat",   1.0) + sc("hat",   0.0) +
             sc("hat",   1.0) + sc("hat",   0.0) + sc("hat",   1.0) + sc("hat",   0.0),
})

time.sleep(5)
done.set()
mm.disconnect()

print(f"\n{'ms':>7}  {'label':<8}  value")
print("-" * 28)
for ts, params in log:
    label = params[0] if params else "?"
    value = params[1] if len(params) > 1 else "?"
    print(f"{ts*1000:7.1f}  {label:<8}  {value}")

print("\n=== scheduler cycle log ===")
try:
    with open("/tmp/midiman-sched.log") as f:
        lines = [l.strip() for l in f if "SCHED" in l]
        for l in lines[:40]:
            print(l)
except: pass
PYEOF
