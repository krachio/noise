{
  "$schema": "https://jupyter-lite.readthedocs.io/en/latest/_static/schema/jupyter-lite.v0.schema.json",
  "jupyter-lite-schema-version": 0,
  "jupyter-config-data": {
    "appName": "krach REPL",
    "disabledExtensions": [
      "@jupyterlite/server-extension"
    ],
    "settingsOverrides": {
      "@jupyterlab/apputils-extension:themes": {
        "theme": "JupyterLab Dark"
      }
    },
    "litePluginSettings": {
      "@jupyterlite/pyodide-kernel-extension:kernel": {
        "pipliteWheelUrl": "../pypi/all.json",
        "pipliteUrls": ["../pypi/all.json"]
      }
    }
  }
}
